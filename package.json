{
  "name": "@krislintigo/eslint-config",
  "version": "1.5.2",
  "description": "Shared ESLint flat config for TypeScript projects.",
  "type": "module",
  "license": "MIT",
  "author": "krislintigo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krislintigo/eslint-config.git"
  },
  "homepage": "https://github.com/krislintigo/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/krislintigo/eslint-config/issues"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.13.1"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "types": "./src/index.d.ts",
  "scripts": {
    "check": "node --check src/index.js && pnpm pack --pack-destination /tmp",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "typescript"
  ],
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": ">=6.0.0 <7.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.5.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^68.0.0",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.61.1"
  }
}
